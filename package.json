{
  "name": "dota2-trainer",
  "version": "0.2.4",
  "description": "Dota2 三号位个人训练工具",
  "main": "dist/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "test": "vitest run",
    "preview": "electron-vite preview",
    "update:matchups": "node scripts/updateHeroMatchupSnapshot.mjs",
    "validate:matchups": "node scripts/updateHeroMatchupSnapshot.mjs --validate-only",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "update:position-meta": "node scripts/updatePositionMetaHeroes.mjs",
    "validate:position-meta": "node scripts/validatePositionMetaHeroes.mjs",
    "validate:position-pools": "node scripts/validatePositionHeroPools.mjs"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "nanoid": "^5.0.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.27.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
